{
  "name": "rbx-ai",
  "version": "1.0.0",
  "description": "RBX-AI - Multi-Provider AI Chat Application",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "Darashad171",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-build": "npm run build && electron-builder",
    "start": "npm run electron-build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "bootstrap": "^5.3.2",
    "axios": "^1.6.2",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "electron": "27.0.0",
    "electron-builder": "^24.6.4",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.rbxai.app",
    "productName": "RBX-AI",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "public/electron.js",
      "public/preload.js"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
